# --- Core API Configuration (Go) ---
PORT=8080
ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_password
DB_NAME=chat_db
DB_SSLMODE=disable

# Database (ScyllaDB)
SCYLLA_HOSTS=localhost:9042
SCYLLA_KEYSPACE=chat_messages

# Caching (Valkey)
VALKEY_HOST=localhost
VALKEY_PORT=6379

# Message Queue (NATS)
NATS_URL=nats://localhost:4222

# Token security
PASETO_SYMMETRIC_KEY=yellow-submarine-yellow-submarin # Phải là 32 bytes cho v4.local

# gRPC Server
GRPC_PORT=50051

# Object Storage (SeaweedFS)
SEAWEEDFS_S3_ENDPOINT=http://localhost:8333
SEAWEEDFS_ACCESS_KEY=any_access_key
SEAWEEDFS_SECRET_KEY=any_secret_key
SEAWEEDFS_BUCKET=chat-media

# --- Gateway Configuration (Rust) ---
GATEWAY_PORT=8081
CORE_API_GRPC_URL=http://localhost:50051

# --- LiveKit WebRTC Configuration (Phase 6) ---
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
